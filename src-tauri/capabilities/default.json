{
  "$schema": "https://raw.githubusercontent.com/nicktomlin/tauri/tauri-v2/crates/tauri/schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-appdata-read",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appcache-read",
    "fs:allow-appcache-read-recursive",
    "fs:allow-appcache-write",
    "fs:allow-appcache-write-recursive",
    "fs:allow-resource-read",
    "fs:allow-resource-read-recursive",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "scope": {
        "allow": [
          {
            "name": "ffmpeg",
            "cmd": "ffmpeg",
            "args": true
          },
          {
            "name": "ffmpeg.exe",
            "cmd": "ffmpeg.exe",
            "args": true
          }
        ]
      }
    }
  ]
}
